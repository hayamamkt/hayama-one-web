{
  "name": "hayama-one-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run start:shell & npm run start:todos",
    "start:shell": "ng serve shell",
    "start:todos": "ng serve todos --port=4300",
    "build:shell": "ng build shell",
    "build:todos": "ng build todos",
    "watch:shell": "ng build shell --watch --configuration development",
    "test": "ng test",
    "serve:ssr:shell": "node dist/shell/server/server.mjs",
    "serve:ssr:works": "node dist/works/server/server.mjs"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.1.0",
    "@angular/common": "^20.1.0",
    "@angular/compiler": "^20.1.0",
    "@angular/core": "^20.1.0",
    "@angular/forms": "^20.1.0",
    "@angular/platform-browser": "^20.1.0",
    "@angular/platform-server": "^20.1.0",
    "@angular/router": "^20.1.0",
    "@angular/ssr": "^20.2.2",
    "@softarc/native-federation-node": "^2.0.10",
    "@tailwindcss/postcss": "^4.1.13",
    "cors": "^2.8.5",
    "es-module-shims": "^1.5.12",
    "express": "^5.1.0",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.13",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-architects/native-federation": "^20.1.6",
    "@angular-devkit/build-angular": "^20.2.2",
    "@angular/build": "^20.2.2",
    "@angular/cli": "^20.1.4",
    "@angular/compiler-cli": "^20.1.0",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.17.19",
    "daisyui": "^5.1.10",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.2.0",
    "typescript": "~5.8.2"
  }
}
